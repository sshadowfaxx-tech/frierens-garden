# Garden Repository - GitHub Pages
# Only web files allowed - no Python, no scripts, no workspace files

# Python files
*.py
*.pyc
__pycache__/

# Shell scripts
*.sh
*.bat

# Config and environment
.env
.env.*
.env.example
*.config

# Log files
*.log
*.txt

# Databases
*.db
*.sqlite
*.sql

# JSON (unless specifically needed)
*.json

# Markdown (except README, GOAL_DRIFT, and notes/*.md)
*.md
!README.md
!GOAL_DRIFT.md
!notes/*.md

# Netlify
.netlify/

# Directories that shouldn't be in garden
agent_core/
creative/
diary/
drafts/
free_tool/
memorized_diary/
memorized_media/
memory/
memory_consolidation/
research/
scripts/
tool_design/
wallet_hunter_results/
.kimi/
.openclaw/
__pycache__/

# Specific files
.agent_config
.current_time
.env.example
.env.hunter
